#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}=== GPG/Yubikey Key Verification ===${NC}"
echo ""
echo -e "${YELLOW}Keys for sops are stored on your Yubikey and accessed via gpg-agent.${NC}"
echo -e "${YELLOW}No key files need to be copied.${NC}"
echo ""

check_gpg() {
  if ! command -v gpg >/dev/null 2>&1; then
    echo -e "${RED}gpg is not installed or not in PATH.${NC}"
    exit 1
  fi
  echo -e "${GREEN}gpg is available.${NC}"
}

check_yubikey() {
  if gpg --card-status >/dev/null 2>&1; then
    echo -e "${GREEN}Yubikey detected and accessible.${NC}"
  else
    echo -e "${RED}No Yubikey detected. Insert your Yubikey and try again.${NC}"
    exit 1
  fi
}

check_gpg_keys() {
  local secret_keys
  secret_keys=$(gpg --list-secret-keys --keyid-format long 2>/dev/null)

  if [ -n "$secret_keys" ]; then
    echo -e "${GREEN}GPG secret keys found:${NC}"
    echo "$secret_keys"
  else
    echo -e "${RED}No GPG secret keys found.${NC}"
    echo -e "${RED}Run the create-keys script to set up your Yubikey GPG keys.${NC}"
    exit 1
  fi
}

check_gpg
check_yubikey
check_gpg_keys

echo ""
echo -e "${GREEN}Yubikey GPG keys are available. No copying needed.${NC}"
