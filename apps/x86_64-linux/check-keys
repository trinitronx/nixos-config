#!/usr/bin/env bash
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

check_gpg() {
  if command -v gpg >/dev/null 2>&1; then
    echo -e "${GREEN}gpg is available.${NC}"
  else
    echo -e "${RED}gpg is not installed or not in PATH.${NC}"
    exit 1
  fi
}

check_gpg_keys() {
  local secret_keys
  secret_keys=$(gpg --list-secret-keys --keyid-format long 2>/dev/null)

  if [ -n "$secret_keys" ]; then
    echo -e "${GREEN}GPG secret keys found:${NC}"
    echo "$secret_keys"
  else
    echo -e "${RED}No GPG secret keys found.${NC}"
    echo -e "${RED}Ensure your Yubikey is inserted and gpg-agent can access it.${NC}"
    echo -e "${RED}Try: gpg --card-status${NC}"
    exit 1
  fi
}

check_sops() {
  if command -v sops >/dev/null 2>&1; then
    echo -e "${GREEN}sops is available.${NC}"
  else
    echo -e "${RED}sops is not installed or not in PATH.${NC}"
    echo -e "${RED}Run 'nix develop' to enter the dev shell with sops.${NC}"
    exit 1
  fi
}

echo "Checking sops + GPG/Yubikey prerequisites..."
echo ""
check_gpg
check_gpg_keys
check_sops

echo ""
echo -e "${GREEN}All checks passed. Ready for sops secret management.${NC}"
